{
  "name": "jarvis-claude",
  "version": "1.0.0",
  "private": true,
  "description": "JARVIS-style voice UI that drives the Claude Code CLI",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build && electron-builder",
    "typecheck": "tsc --noEmit",
    "start": "electron-vite preview"
  },
  "dependencies": {
    "@react-three/drei": "^10.0.0",
    "@react-three/fiber": "^9.0.0",
    "@ricky0123/vad-web": "^0.0.30",
    "fix-path": "^4.0.0",
    "framer-motion": "^11.5.4",
    "nodejs-whisper": "^0.3.0",
    "onnxruntime-web": "^1.26.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "three": "^0.169.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.169.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^33.4.11",
    "electron-builder": "^25.0.0",
    "electron-vite": "^2.3.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vite-plugin-static-copy": "^4.1.0"
  },
  "build": {
    "appId": "com.user.jarvis-claude",
    "productName": "Jarvis",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.developer-tools"
    }
  }
}
